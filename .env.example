# ── EduUpcycle – Configuratie ─────────────────────────────────────────
# Kopieer dit bestand naar .env.local en vul je keys in.

# ── AI (verplicht voor echte analyse) ─────────────────────────────────
# Groq API key (gratis tier: https://console.groq.com)
# Zonder API key draait de app in demo-modus.
GROQ_API_KEY=gsk_...

# Optioneel: gebruik een ander model (standaard: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Supabase (optioneel, voor database-opslag en student-links) ────────
# Maak een gratis project aan op https://supabase.com
# Voer daarna de migratie uit: supabase/migration.sql
#
# Vind je keys in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://jouw-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
